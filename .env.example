# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Solana RPC endpoint.
# The public one works but is rate-limited. For anything real, use a free
# Helius / QuickNode / Alchemy endpoint, e.g.:
#   https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# How often to check tracked wallets, in seconds.
POLL_INTERVAL=30

# Only notify when the wallet receives at least this many SOL (set 0 for any inflow).
MIN_SOL=0
